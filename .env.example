# Copy to .env and fill in. All keys are optional for paper mode — in that case
# ARIA runs with TA-only fallback for the LLM and empty external feeds.

# --- Exchange (Binance Futures) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- LLM ---
# Default provider is OpenRouter (1 key, banyak model). Buat key di:
#   https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Alternatif provider — set salah satu sesuai `[llm.provider]` di config:
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# TOGETHER_API_KEY=
# GROQ_API_KEY=

# --- News & sentiment feeds ---
CRYPTOPANIC_API_KEY=
LUNARCRUSH_API_KEY=

# --- On-chain feeds ---
GLASSNODE_API_KEY=
WHALE_ALERT_API_KEY=

# --- Telegram alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Misc ---
ARIA_CONFIG_OVERLAY=config/paper.toml
RUST_LOG=info
